# API Configuration
# Point this to your API server URL
# For production: Use your domain
# For local dev: Use localhost
NEXT_PUBLIC_API_URL=http://knoxdev.org:3000

# Master Admin Domain
# This is used to detect if the user is accessing the master admin portal
# For production: Use your domain (without http://)
# For local dev: Use localhost:3001
NEXT_PUBLIC_MASTER_DOMAIN=knoxdev.org:3001

# App Configuration
NEXT_PUBLIC_APP_NAME=Bluestone Apps
NEXT_PUBLIC_APP_VERSION=1.0.0

# For local development, you can also use:
# NEXT_PUBLIC_API_URL=http://localhost:3000
# NEXT_PUBLIC_MASTER_DOMAIN=localhost:3001
